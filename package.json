{
  "name": "markdown-editor-mira",
  "version": "0.0.2",
  "description": "An Obsidian-like WYSIWYG Markdown editor",
  "main": "public/index.html",
  "scripts": {
    "dev": "npx http-server public -p 8080",
    "build": "npm run build:editor && npm run build:css",
    "build:editor": "echo 'Building editor...'",
    "build:css": "echo 'Building CSS...'",
    "deploy": "vercel --prod"
  },
  "keywords": ["markdown", "editor", "wysiwyg", "obsidian"],
  "author": "Mira",
  "license": "MIT",
  "dependencies": {
    "@tiptap/core": "^2.2.4",
    "@tiptap/extension-bold": "^2.2.4",
    "@tiptap/extension-bullet-list": "^2.2.4",
    "@tiptap/extension-document": "^2.2.4",
    "@tiptap/extension-italic": "^2.2.4",
    "@tiptap/extension-list-item": "^2.2.4",
    "@tiptap/extension-paragraph": "^2.2.4",
    "@tiptap/extension-strike": "^2.2.4",
    "@tiptap/extension-text": "^2.2.4",
    "@tiptap/extension-heading": "^2.2.4",
    "@tiptap/extension-code": "^2.2.4",
    "@tiptap/extension-code-block-lowlight": "^2.2.4",
    "@tiptap/pm": "^2.2.4",
    "@tiptap/starter-kit": "^2.2.4",
    "lowlight": "^3.1.0",
    "marked": "^11.1.1"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "vercel": "^32.7.2"
  }
}
